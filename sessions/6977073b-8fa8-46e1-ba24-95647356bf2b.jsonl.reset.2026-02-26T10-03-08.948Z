cheRead":19392,"cacheWrite":0,"totalTokens":21426,"cost":{"input":0.0005551800000000001,"output":0.0009741,"cacheRead":0.00368448,"cacheWrite":0,"total":0.00521376}},"stopReason":"stop","timestamp":1772099591600}}
